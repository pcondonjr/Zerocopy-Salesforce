# Copy to .env and fill in your values. NEVER commit .env to git.

# Your Neon connection string — from neon.tech → Connection Details
DATABASE_URL=postgres://user:password@ep-xyz-123.us-east-2.aws.neon.tech/neondb?sslmode=require

# Number of records to generate (reduce to 200000 if near Neon's free 3GB limit)
TOTAL_RECORDS=500000

# Batch size — higher = faster inserts, more memory used
BATCH_SIZE=1000
